{
    "name": "webfiori/mailer",
    "description": "Sockets-based library for sending HTML email messages.",
    "type": "library",
    "version": "2.1.1",
    "authors": [
        {
            "name": "Ibrahim BinAlshikh",
            "email": "ibrahim@webfiori.com"
        }
    ],
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "webfiori/file": "2.0.*",
        "webfiori/ui": "4.0.*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10",
        "friendsofphp/php-cs-fixer": "^3.86",
        "webfiori/oauth": "1.0.*"
    },
    "keywords": [
        "php",
        "email",
        "mail",
        "html",
        "sockets"
    ],
    "scripts": {
        "test": "vendor/bin/phpunit -c tests/phpunit.xml",
        "test-integration": "vendor/bin/phpunit -c tests/phpunit-integration.xml",
        "fix-cs": "vendor/bin/php-cs-fixer fix --config=php_cs.php.dist"
    },
    "autoload": {
        "psr-4": {
            "WebFiori\\Mail\\": "WebFiori/Mail/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "WebFiori\\Tests\\Mail\\": "tests/WebFiori/Tests/Mail/"
        }
    }
}
