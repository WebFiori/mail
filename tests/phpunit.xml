<?xml version="1.0" encoding="UTF-8"?>
<phpunit stderr="true" colors="true" bootstrap="bootstrap.php" displayDetailsOnSkippedTests="true">
    <filter>
        <whitelist addUncoveredFilesFromWhitelist="true">
            <file>../WebFiori/Mail/Email.php</file>
            <file>../WebFiori/Mail/SMTPAccount.php</file>
            <file>../WebFiori/Mail/SMTPServer.php</file>
        </whitelist>
    </filter>
    <logging>
        <log type="coverage-clover" target="clover.xml"/>
    </logging>
    <testsuites>
        <testsuite name="Unit Tests">
            <directory>./WebFiori/Tests/Mail</directory>
            <exclude>./WebFiori/Tests/Mail/IntegrationTest.php</exclude>
        </testsuite>
    </testsuites>
</phpunit>
